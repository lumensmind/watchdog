{
  "watches": [
    {
      "id": "example-http",
      "name": "example http check",
      "type": "http",
      "enabled": false,
      "url": "https://example.com",
      "timeout_s": 10,
      "expect_status": 200
    },
    {
      "id": "example-disk",
      "name": "root disk usage",
      "type": "system_disk",
      "enabled": false,
      "path": "/",
      "warn_above_pct": 85
    },
    {
      "id": "example-cpu",
      "name": "cpu load",
      "type": "system_cpu",
      "enabled": false,
      "warn_above_pct": 90
    },
    {
      "id": "example-memory",
      "name": "memory usage",
      "type": "system_memory",
      "enabled": false,
      "warn_above_pct": 90
    },
    {
      "id": "example-rss",
      "name": "hacker news feed",