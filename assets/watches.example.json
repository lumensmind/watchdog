{
  "watches": [
    {
      "id": "api-health",
      "name": "production api",
      "type": "http",
      "url": "https://api.example.com/health",
      "expect_status": 200,
      "timeout_s": 5,
      "enabled": true
    },
    {
      "id": "disk-home",
      "name": "home disk space",
      "type": "system_disk",
      "path": "/home",
      "alert_threshold_pct": 85,
      "enabled": true
    },
    {
      "id": "cpu-load",
      "name": "cpu usage",
      "type": "system_cpu",
      "alert_threshold_pct": 90,
      "enabled": true
    },
    {
      "id": "memory-usage",
      "name": "memory pressure",
      "type": "system_memory",
      "alert_threshold_pct": 90,
      "enabled": true
    },
    {
      "id": "openclaw-blog",
      "name": "openclaw blog",
      "type": "rss",
      "url": "https://openclaw.ai/blog/rss.xml",
      "enabled": true
    },
    {
      "id": "service-nginx",
      "name": "nginx running",
      "type": "command",
      "command": "systemctl is-active nginx",
      "expect_exit": 0,
      "timeout_s": 5,
      "enabled": false
    }
  ]
}
